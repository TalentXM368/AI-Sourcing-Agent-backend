generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Candidates ───────────────────────────────────────────────

model Candidate {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  email           String?
  phone           String?
  linkedinUrl     String?   @map("linkedin_url")
  githubUrl       String?   @map("github_url")
  portfolioUrl    String?   @map("portfolio_url")
  headline        String?
  location        String?
  summary         String?
  experienceYears Float?    @map("experience_years")
  skills          Json      @default("[]")
  companies       Json      @default("[]")
  workHistory     Json      @default("[]") @map("work_history")
  education       Json      @default("[]")
  projects        Json      @default("[]")
  certifications  Json      @default("[]")
  languages       Json      @default("[]")
  resumeUrl       String?   @map("resume_url")
  rawText         String?   @map("raw_text")
  sourceFile      String?   @map("source_file")
  parseStatus     String    @default("pending") @map("parse_status")
  parseError      String?   @map("parse_error")
  dataQualityScore Int?     @map("data_quality_score")
  missingFields   String[]  @default([]) @map("missing_fields")
  stage           String    @default("new")
  stageUpdatedAt  DateTime? @map("stage_updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  embeddings      Embedding[]
  rankedCandidates RankedCandidate[]

  @@unique([sourceFile])
  @@map("candidates")
}

// ─── Jobs ─────────────────────────────────────────────────────

model Job {
  id                String    @id @default(uuid()) @db.Uuid
  clientId          String?   @map("client_id") @db.Uuid
  role              String
  company           String?
  location          String?
  requiredSkills    String[]  @default([]) @map("required_skills")
  niceToHaveSkills  String[]  @default([]) @map("nice_to_have_skills")
  avoidSkills       String[]  @default([]) @map("avoid_skills")
  experienceMin     Int?      @map("experience_min")
  experienceMax     Int?      @map("experience_max")
  description       String?
  rawText           String?   @map("raw_text")
  status            String    @default("open")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  client            Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  embeddings        Embedding[]
  rankedCandidates  RankedCandidate[]

  @@map("jobs")
}

// ─── Clients ──────────────────────────────────────────────────

model Client {
  id                  String    @id @default(uuid()) @db.Uuid
  zohoAccountId       String?   @unique @map("zoho_account_id")
  accountName         String    @map("account_name")
  industry            String?
  location            String?
  status              String    @default("active")
  urgency             String    @default("medium")
  openRoles           Int       @default(0) @map("open_roles")
  placementsYtd       Int       @default(0) @map("placements_ytd")
  hiringPreferences   Json      @default("{}") @map("hiring_preferences")
  culture             Json      @default("{}")
  roleContext          Json      @default("{}") @map("role_context")
  historicalPatterns  Json      @default("{}") @map("historical_patterns")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  jobs                Job[]

  @@map("clients")
}

// ─── Embeddings ───────────────────────────────────────────────

model Embedding {
  id           String   @id @default(uuid()) @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id") @db.Uuid
  purpose      String
  vector       Unsupported("float[]")
  model        String   @default("text-embedding-3-small")
  createdAt    DateTime @default(now()) @map("created_at")

  candidate    Candidate? @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "embeddings_candidate_id_fkey")
  job          Job?       @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "embeddings_job_id_fkey")

  @@unique([entityType, entityId, purpose])
  @@index([entityType, entityId])
  @@map("embeddings")
}

// ─── Ranked Candidates ────────────────────────────────────────

model RankedCandidate {
  id               String    @id @default(uuid()) @db.Uuid
  jobId            String    @map("job_id") @db.Uuid
  candidateId      String    @map("candidate_id") @db.Uuid
  semanticScore    Float     @default(0) @map("semantic_score")
  skillScore       Float     @default(0) @map("skill_score")
  experienceScore  Float     @default(0) @map("experience_score")
  educationScore   Float     @default(0) @map("education_score")
  clientFitScore   Float     @default(0) @map("client_fit_score")
  totalScore       Float     @default(0) @map("total_score")
  exactMatches     String[]  @default([]) @map("exact_matches")
  semanticMatches  String[]  @default([]) @map("semantic_matches")
  missingSkills    String[]  @default([]) @map("missing_skills")
  avoidSignals     String[]  @default([]) @map("avoid_signals")
  explanation      String?
  llmScore         Float     @default(0) @map("llm_score")
  llmVerdict       String?   @map("llm_verdict")
  llmReasoning     String?   @map("llm_reasoning")
  atsScore         Int?      @map("ats_score")
  decision         String    @default("pending")
  createdAt        DateTime  @default(now()) @map("created_at")

  job              Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId, totalScore(sort: Desc)])
  @@index([jobId, decision])
  @@map("ranked_candidates")
}
